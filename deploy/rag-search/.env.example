# Bootstrap image versions. Resolve and pin registry digests in production.
OPENSEARCH_IMAGE=opensearchproject/opensearch:3.7.0
RAG_SEARCH_PYTHON_IMAGE=python:3.12-slim

# OpenSearch is published on loopback by default. Keep the Security plugin enabled.
OPENSEARCH_PUBLISH_ADDRESS=127.0.0.1
OPENSEARCH_HOST_PORT=9200
OPENSEARCH_CLUSTER_NAME=puncture-rag-search
OPENSEARCH_NODE_NAME=puncture-rag-search-1
OPENSEARCH_JAVA_OPTS=-Xms1g -Xmx1g

# Secrets stay out of this file. Point the host path at a chmod 600 password file.
# /dev/null is a fail-closed placeholder: the entrypoint will refuse to start.
OPENSEARCH_ADMIN_PASSWORD_FILE_HOST=/dev/null
OPENSEARCH_CA_FILE_HOST=/dev/null

# Container-to-container verification uses the image's bootstrap TLS certificate.
# This is an explicit local bootstrap setting, not a production TLS policy.
OPENSEARCH_ENDPOINT=https://opensearch:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_INSECURE=true

# Versioned index and atomic aliases.
RAG_INDEX_TEMPLATE_NAME=puncture-rag-template-v1
RAG_INDEX_NAME=puncture-rag-v000001
RAG_READ_ALIAS=puncture-rag-read
RAG_WRITE_ALIAS=puncture-rag-write
RAG_SCHEMA_VERSION=1

# Qwen3 embedding bootstrap profile. Replace both revision placeholders with the
# exact immutable model/tokenizer checkpoint revision used by the private service.
RAG_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
RAG_EMBEDDING_REVISION=SET_IMMUTABLE_QWEN3_EMBEDDING_REVISION
RAG_EMBEDDING_DIMENSION=1024
RAG_QUERY_INSTRUCTION="Retrieve relevant internal engineering passages that answer the query."
RAG_DOCUMENT_INSTRUCTION=
RAG_VECTORS_NORMALIZED=true
RAG_TOKENIZER_REVISION=SET_IMMUTABLE_QWEN3_TOKENIZER_REVISION
RAG_MAX_INPUT_TOKENS=8192
RAG_PARSER_VERSION=1
RAG_CHUNKER_VERSION=1

# Verification waits; no measured latency claim is implied by these limits.
RAG_HEALTH_WAIT_SECONDS=180
RAG_REQUEST_TIMEOUT_SECONDS=15
