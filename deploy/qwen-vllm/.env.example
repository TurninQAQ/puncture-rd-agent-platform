# Bootstrap values only. Production must pin the image digest and model revision.
VLLM_IMAGE=vllm/vllm-openai:v0.25.0
VLLM_MODEL_ID=Qwen/Qwen3-8B
VLLM_MODEL_REVISION=main
VLLM_SERVED_MODEL_NAME=qwen-enterprise-agent

# Host exposure is loopback by default. Put an authenticated gateway in front of it.
VLLM_PUBLISH_ADDRESS=127.0.0.1
VLLM_HOST_PORT=8000
VLLM_CONTAINER_PORT=8000
VLLM_SHM_SIZE=16gb
VLLM_MODEL_CACHE=./model-cache

# GPU and scheduler settings. CUDA_VISIBLE_DEVICES count must be >= tensor parallel size.
CUDA_VISIBLE_DEVICES=0
GPU_COUNT=1
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_MAX_MODEL_LEN=8192
VLLM_GPU_MEMORY_UTILIZATION=0.90
VLLM_MAX_NUM_SEQS=16
VLLM_MAX_NUM_BATCHED_TOKENS=
VLLM_SWAP_SPACE_GB=4
VLLM_CPU_OFFLOAD_GB=0

# Loading and precision settings. Leave optional values blank to omit their CLI flag.
VLLM_DTYPE=auto
VLLM_KV_CACHE_DTYPE=auto
VLLM_QUANTIZATION=
VLLM_LOAD_FORMAT=auto
VLLM_GENERATION_CONFIG=vllm
VLLM_TRUST_REMOTE_CODE=false
VLLM_ENFORCE_EAGER=false
VLLM_ENABLE_PREFIX_CACHING=true
VLLM_ENABLE_CHUNKED_PREFILL=true

# Tool calling. Parser names are vLLM/model-version-sensitive; verify with `vllm serve --help`.
VLLM_ENABLE_AUTO_TOOL_CHOICE=true
VLLM_TOOL_CALL_PARSER=hermes
VLLM_TOOL_PARSER_PLUGIN=
VLLM_CHAT_TEMPLATE_PATH=
VLLM_REASONING_PARSER=
VLLM_ENABLE_REASONING_LEGACY_FLAG=false

# Structured output flag compatibility:
#   none    = rely on request-level response_format/structured_outputs support
#   legacy  = add --guided-decoding-backend
#   config  = add --structured-outputs-config.backend
VLLM_STRUCTURED_OUTPUT_FLAG_STYLE=none
VLLM_STRUCTURED_OUTPUT_BACKEND=
VLLM_STRUCTURED_OUTPUT_ENABLE_IN_REASONING=false

# Request/privacy controls.
VLLM_DISABLE_LOG_REQUESTS=true
VLLM_UVICORN_LOG_LEVEL=info

# Keep secrets blank in files. Compose mounts /dev/null for unauthenticated bootstrap;
# production must point these host paths at permission-restricted secret files.
VLLM_API_KEY_FILE_HOST=/dev/null
HF_TOKEN_FILE_HOST=/dev/null
VLLM_API_KEY=
VLLM_API_KEY_FILE=
HF_TOKEN=
HF_TOKEN_FILE=

# Verification and benchmark defaults.
VERIFY_BASE_URL=http://qwen-vllm:8000/v1
VERIFY_TIMEOUT_SECONDS=120
BENCHMARK_REQUESTS=20
BENCHMARK_CONCURRENCY=1
BENCHMARK_MAX_TOKENS=128
BENCHMARK_STREAM=true
