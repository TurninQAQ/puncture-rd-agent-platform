# Copy to .env, chmod 600, replace the three local path/DSN placeholders,
# and set the explicit opt-in to 1. Values are parsed literally, never sourced.
RUN_FULL_STACK_DEMO=0
PUNCTURE_API_POSTGRES_DSN=postgresql://USER:REPLACE_ME@127.0.0.1:5432/puncture_agent
PUNCTURE_API_POSTGRES_SCHEMA=puncture_local_demo
PUNCTURE_DEMO_HOST=127.0.0.1
PUNCTURE_DEMO_PORT=8010
PUNCTURE_DEMO_BASE_URL=http://127.0.0.1:8010
PUNCTURE_DEMO_TOKEN_FILE=var/local-demo/bearer-token
PUNCTURE_DEMO_CASE_IDS=Case-102,Case-203
VLLM_BASE_URL=http://127.0.0.1:8008/v1
VLLM_MODEL=qwen-enterprise-agent
VLLM_TIMEOUT_SECONDS=120
OPENSEARCH_ENDPOINT=https://127.0.0.1:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD_FILE=/absolute/path/to/opensearch-client-password
OPENSEARCH_CA_FILE=/absolute/path/to/opensearch-root-ca.pem
OPENSEARCH_INSECURE=false
RAG_READ_ALIAS=puncture-rag-read
RAG_WRITE_ALIAS=puncture-rag-write
